# Mole clean whitelist — paths that mo clean must NOT delete.
# This file REPLACES mole's built-in defaults, so it re-lists them.
# Symlinked to ~/.config/mole/whitelist by bootstrap.

# --- Mole built-in defaults (from DEFAULT_WHITELIST_PATTERNS) ---
~/Library/Caches/ms-playwright*
~/.cache/huggingface*
~/.m2/repository/*
~/.gradle/caches/*
~/.gradle/daemon/*
~/.ollama/models/*
~/Library/Caches/com.nssurge.surge-mac/*
~/Library/Application Support/com.nssurge.surge-mac/*
~/Library/Caches/org.R-project.R/R/renv/*
~/Library/Caches/pypoetry/virtualenvs*
~/Library/Caches/JetBrains*
~/Library/Caches/com.jetbrains.toolbox*
~/Library/Caches/tealdeer/tldr-pages
~/Library/Application Support/JetBrains*
~/Library/Caches/com.apple.finder
~/Library/Mobile Documents*
~/Library/Caches/com.apple.FontRegistry*
~/Library/Caches/com.apple.spotlight*
~/Library/Caches/com.apple.Spotlight*
~/Library/Caches/CloudKit*
FINDER_METADATA

# --- Local additions ---
# antidote clones zsh plugins here; wiping it breaks the shell until rebundled.
~/Library/Caches/antidote*
