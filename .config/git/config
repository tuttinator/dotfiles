[user]
	name = Caleb Tutty
	email = caleb.tutty@gmail.com

[alias]
	st = status
	lol = log --graph --decorate --pretty=oneline --abbrev-commit
	lola = log --graph --decorate --pretty=oneline --abbrev-commit --all
	graph = log --graph --color --pretty=format:"%C(yellow)%H%C(green)%d%C(reset)%n%x20%cd%n%x20%cn%C(blue)%x20(%ce)%x20%C(cyan)[gpg:%GK%x20%G?]%C(reset)%n%x20%s%n"

[init]
	defaultBranch = main

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true         # n / N to jump between diff sections
	light = false
	line-numbers = true
	side-by-side = false    # flip to true if you prefer side-by-side
	syntax-theme = Monokai Extended

[pull]
	ff = only

[push]
	autoSetupRemote = true

[fetch]
	prune = true

[rebase]
	autoStash = true

[rerere]
	enabled = true

[column]
	ui = auto

[branch]
	sort = -committerdate

[diff]
	algorithm = histogram
	colorMoved = default
	renames = copies

[merge]
	conflictStyle = zdiff3

[color]
	ui = true
